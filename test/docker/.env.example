# Copy to test/docker/.env (gitignored) and fill in. Passed via `docker run --env-file`.
# These are CLIENT credentials used to pull through Artifactory and trigger the
# Worker — they are NOT Worker runtime config (the Worker reads no secrets).

# Platform/Artifactory base URL. Keep the /artifactory suffix; the entrypoint
# strips it for `jf config add --url` (which wants the platform root).
ARTIFACTORY_URL=https://<company>.jfrog.io/artifactory

# Access token for the above. Needs read on the test virtual + cache repos and
# delete on the cache repo (the harness evicts to force an uncached fetch).
ARTIFACTORY_TOKEN=

# Required: test repo keys. The gate-test.sh harness aborts with an error if any
# of these are unset. Set them to the virtual, remote, and cache repo keys for
# your npm test repos. The Before Remote Download event fires on the remote, so
# the Worker's manifest repoKeys must include GATE_REMOTE.
GATE_VIRTUAL=<npm-virtual-key>
GATE_REMOTE=<npm-remote-key>
GATE_CACHE=<npm-cache-key>

# Optional overrides.
# JF_SERVER_ID=artifactory
# GATE_MIN_AGE_HOURS=48